{
  "name": "CTFd K8s Challenges",
  "dockerComposeFile": "docker-compose.yml",
  "service": "node",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "remoteUser": "root",
  "overrideCommand": true,
  "forwardPorts": [3000, 3011, 3012],
  "portsAttributes": {
    "3000": { "label": "CTFd" },
    "3011": { "label": "Node.js" },
    "3012": { "label": "phpMyAdmin" }
  },
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/root/.gitconfig,type=bind"
  ],
  "settings": {
    "terminal.integrated.defaultProfile.linux": "bash"
  },
  "postCreateCommand": "([ -f /workspace/k8s-client/package.json ] && npm install --prefix /workspace/k8s-client) || true"
}
