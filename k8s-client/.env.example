# =====================================================================
# CTFd K8s Orchestrator Configuration
# =====================================================================
# This orchestrator handles container deployment for CTFd challenges.
# It receives deployment requests from CTFd via API.
#
# IMPORTANT: Most settings (domain suffix, port ranges, container limits)
# are now configured in CTFd's admin panel and passed via API requests.
# Only infrastructure-level settings are configured here.
# =====================================================================

# API Server Port
PORT=3000

# =====================================================================
# Authentication
# =====================================================================

# API key for authenticating requests from CTFd (REQUIRED)
# This MUST match the API key set in CTFd's plugin configuration
X_API_KEY=your-secret-key-here
# API_KEY is an alias for X_API_KEY
# API_KEY=your-secret-key-here

# =====================================================================
# Kubernetes Configuration
# =====================================================================

# Namespace where challenge containers will be deployed
CHALLENGE_NAMESPACE=ctfd-challenges

# Kubernetes authentication:
# - If KUBERNETES_SERVICE_HOST is set: uses in-cluster auth (when running in k8s)
# - Otherwise: uses kubeconfig from ~/.kube/config

# =====================================================================
# Ingress Configuration (for HTTP/Web Challenges)
# =====================================================================

# Ingress class for routing web challenges
INGRESS_CLASS=nginx

# Enable HTTPS for web challenges
TLS_ENABLED=true

# TLS certificate secret name (must exist in CHALLENGE_NAMESPACE)
# This secret should contain a wildcard certificate for your domain
# Example: Certificate for *.sillyctf-challenges.psuccso.org
# The secret should have keys: tls.crt and tls.key
TLS_CERT_SECRET=wildcard-tls-cert

# =====================================================================
# Container Lifecycle
# =====================================================================

# Reaper interval (milliseconds) - how often to check for expired containers
REAPER_INTERVAL_MS=60000

# =====================================================================
# Settings Configured in CTFd (DO NOT SET HERE)
# =====================================================================
# The following are configured in CTFd's admin panel at:
# /admin/plugins/k8s-challenges
#
# These values are passed to the orchestrator in each API request:
# - Domain Suffix (e.g., .sillyctf-challenges.psuccso.org)
# - TCP Port Range (e.g., 30000-32767)
# - Max Containers Global (e.g., 100)
# - Max Containers Per Team (e.g., 5)
# - Challenge Prefix (set per-challenge for HTTP challenges)
# =====================================================================
