# API key sent as X-API-KEY header. If unset, key check is skipped (dev only).
X_API_KEY=your-secret
# API_KEY is an alias for X_API_KEY.

# Kubernetes
CHALLENGE_NAMESPACE=ctfd-challenges
# In-cluster auth is used if KUBERNETES_SERVICE_HOST is set; otherwise kubeconfig.

# Networking
ROOT_DOMAIN=sillyctf.psuccso.org
INGRESS_CLASS=nginx
TLS_ENABLED=true

# TCP challenges: host for `nc host port` (defaults to ROOT_DOMAIN)
# TCP_HOST=

# Caps
MAX_CONTAINERS_GLOBAL=500
MAX_CONTAINERS_PER_TEAM=10

# Reaper
REAPER_INTERVAL_MS=60000

PORT=3000
