# Snippet for your existing reverse proxy (e.g. nginx in front of CTFd or at the edge).
# CTFd (cloud) Orchestrator URL → this proxy → internal k8s-client (on‑prem, not public).
#
# Requirements:
#   1. proxy_pass to the internal orchestrator (e.g. rack-proxy.pritunl or k8s-client:3000)
#   2. proxy_set_header Host $proxy_host  so the backend receives the real target as Host

# Replace with your internal orchestrator address (host:port or http://...).
# Examples: http://rack-proxy.pritunl:3000  or  http://k8s-client:3000
upstream ctfd_orchestrator {
    server rack-proxy.pritunl:3000;
}

server {
    listen 443 ssl;
    server_name your-orchestrator.example.com;  # Host that CTFd's Orchestrator URL uses

    # … your ssl_* and other directives …

    location / {
        proxy_pass http://ctfd_orchestrator;
        proxy_http_version 1.1;
        proxy_set_header Host $proxy_host;           # Host = upstream (e.g. rack-proxy.pritunl:3000)
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
        proxy_connect_timeout 10s;
        proxy_send_timeout 60s;
    }
}
